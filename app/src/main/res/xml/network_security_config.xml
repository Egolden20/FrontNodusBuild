<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- Allow cleartext only for local development host -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="false">192.168.18.12</domain>
    </domain-config>
    <!-- Fallback: allow cleartext for emulator loopback if needed -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="false">10.0.2.2</domain>
    </domain-config>
</network-security-config>
