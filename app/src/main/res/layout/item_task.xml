<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardBackgroundColor="@color/teal_primary"
    app:cardCornerRadius="16dp"
    app:cardElevation="4dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Header with Title and Status -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tvTaskTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Inspección de cimentación Bloque A"
                android:textColor="@color/white"
                android:textSize="14sp"
                android:textStyle="bold"
                android:maxLines="2"
                android:ellipsize="end" />

            <TextView
                android:id="@+id/tvTaskStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Nuevo"
                android:textColor="@color/white"
                android:textSize="10sp"
                android:background="@drawable/badge_status"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:paddingTop="4dp"
                android:paddingBottom="4dp"
                android:layout_marginStart="8dp" />
        </LinearLayout>

        <!-- Subtitle -->
        <TextView
            android:id="@+id/tvTaskSubtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Realizado por: Las Terrazas"
            android:textColor="@color/white"
            android:textSize="11sp"
            android:layout_marginTop="4dp" />

        <!-- Footer with Date and Action Button -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="12dp"
            android:gravity="center_vertical">

            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:src="@drawable/ic_calendar_small"
                android:contentDescription="Calendar" />

            <TextView
                android:id="@+id/tvTaskDate"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="2025-10-25"
                android:textColor="@color/white"
                android:textSize="11sp"
                android:layout_marginStart="6dp" />

            <Button
                android:id="@+id/btnTaskAction"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:text="Gestionar"
                android:textColor="@color/teal_dark"
                android:textSize="11sp"
                android:textStyle="bold"
                android:background="@drawable/button_task_action"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:minWidth="0dp"
                android:minHeight="0dp" />
        </LinearLayout>

    </LinearLayout>

</androidx.cardview.widget.CardView>
