<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="CalendarViewCustom" parent="Theme.MaterialComponents.Light">
        <item name="colorAccent">@color/teal_primary</item>
        <item name="android:datePickerStyle">@style/DatePickerStyle</item>
    </style>

    <style name="DatePickerStyle" parent="android:Widget.Material.DatePicker">
        <item name="android:headerBackground">@color/teal_primary</item>
    </style>

    <!-- Calendar specific text appearances to force black numbers -->
    <style name="CalendarWeekDay" parent="TextAppearance.AppCompat.Medium">
        <item name="android:textColor">@color/black</item>
        <item name="android:textSize">12sp</item>
    </style>

    <style name="CalendarDate" parent="TextAppearance.AppCompat.Medium">
        <item name="android:textColor">@color/black</item>
        <item name="android:textSize">14sp</item>
    </style>
</resources>
